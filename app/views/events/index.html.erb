<div class="events-container">
  <h1>Events</h1>

  <div class="events-grid">
    <% @events.each do |event| %>
      <div class="event-card">

        <% if event.image_url.present? %>
          <img src="<%= event.image_url %>" class="event-image">
        <% end %>

        <div class="event-content">

          <div class="event-title">
            <%= event.title %>
          </div>

          <div class="event-meta">
            📍 <%= event.city %> - <%= event.venue_name %>
          </div>

          <div class="event-meta">
            🕒 <%= event.starts_at&.strftime("%d %b %Y, %I:%M %p") %>
          </div>

          <div class="event-price">
            💰
            <%= event.price_cents.present? ? "#{event.price_cents / 100.0} #{event.currency}" : "Free" %>
          </div>

          <!-- ACTION AREA (IMPORTANT for next step) -->
          <div class="event-actions">

            <a href="<%= event.url %>" target="_blank" class="btn btn-outline">
              View
            </a>
            <div class="event-actions">
                <%= button_to "👍 #{event.upvotes_count}",
                    "/events/#{event.id}/upvote",
                    method: :post %>

                <%= button_to "👎 #{event.downvotes_count}",
                    "/events/#{event.id}/downvote",
                    method: :post %>
            </div>
          </div>

          <% vote_history = vote_history_rows_for(event, @vote_history_by_event_id) %>
          <div class="vote-history">
            <h4>Vote History</h4>

            <% if vote_history.any? %>
              <div class="vote-history-table-wrap">
                <table class="vote-history-table">
                  <thead>
                    <tr>
                      <th>user_id</th>
                      <th>latest_vote</th>
                      <th>total_votes_by_user</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% vote_history.each do |row| %>
                      <tr>
                        <td><%= row[:user_id] %></td>
                        <td><%= row[:latest_vote] %></td>
                        <td><%= row[:total_votes_by_user] %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="vote-history-empty">No votes yet.</p>
            <% end %>
          </div>
        </div>

        <% description = event.description.to_s %>
        <div class="event-description">
          <p><%= truncate(description, length: 120) %></p>
          <% if description.length > 120 %>
            <div style="margin-top: 10px;">
              <a href="<%= event.url %>" target="_blank" class="btn btn-outline">
                Read More
              </a>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <div style="margin-top: 30px;">
    <% if @page > 1 %>
      <%= link_to "← Previous", root_path(page: @page - 1) %>
    <% end %>

    <% if @page < @total_pages %>
      <%= link_to "Next →", root_path(page: @page + 1) %>
    <% end %>
  </div>
</div>